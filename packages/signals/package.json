{
  "name": "@chrrrs/signals",
  "version": "0.1.1",
  "description": "Minimal React 19 signals for local state and derived values.",
  "keywords": [
    "react",
    "signals",
    "state",
    "typescript",
    "suspense"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrrrs/signals.git",
    "directory": "packages/signals"
  },
  "homepage": "https://github.com/chrrrs/signals/tree/main/packages/signals",
  "bugs": {
    "url": "https://github.com/chrrrs/signals/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "npm run clean && tsc -b",
    "check-types": "tsc --noEmit",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "jsdom": "^26.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  }
}
